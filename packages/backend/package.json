{
  "name": "@novex/backend",
  "version": "1.0.0",
  "description": "NovEx Crypto Exchange — Backend API",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:engine": "jest --testPathPattern='modules/trading/__tests__' --verbose",
    "test:engine:unit": "jest --testPathPattern='matching-engine\\.spec' --verbose",
    "test:engine:integration": "jest --testPathPattern='trading-settlement\\.spec' --verbose --runInBand",
    "test:market": "jest --testPathPattern='market-orders\\.spec' --verbose --runInBand",
    "test:recon": "jest --testPathPattern='reconciliation/__tests__' --verbose --runInBand",
    "test:concurrency": "jest --testPathPattern='concurrency\\.spec' --verbose --runInBand",
    "test:funding": "jest --testPathPattern='funding/__tests__/funding' --verbose --runInBand",
    "test:admin-controls": "jest --testPathPattern='admin-controls' --verbose --runInBand",
    "test:providers": "jest --testPathPattern='providers/__tests__' --verbose",
    "test:custody": "jest --testPathPattern='custody/__tests__' --verbose",
    "test:governance": "jest --testPathPattern='governance/__tests__' --verbose --runInBand",
    "test:load": "jest --config test/load/jest-load.json --verbose --runInBand",
    "test:load:trading": "jest --config test/load/jest-load.json --testPathPattern='a-trading' --verbose --runInBand",
    "test:load:funding": "jest --config test/load/jest-load.json --testPathPattern='b-funding' --verbose --runInBand",
    "test:load:ws": "jest --config test/load/jest-load.json --testPathPattern='c-websocket' --verbose --runInBand",
    "test:load:failures": "jest --config test/load/jest-load.json --testPathPattern='d-failure' --verbose --runInBand",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/config/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/config/data-source.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/config/data-source.ts",
    "seed": "ts-node -r tsconfig-paths/register src/database/seeds/seed.ts",
    "db:reset": "ts-node -r tsconfig-paths/register src/database/seeds/reset.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/event-emitter": "^2.0.3",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/swagger": "^7.2.0",
    "@nestjs/throttler": "^5.1.0",
    "@nestjs/typeorm": "^10.0.1",
    "@nestjs/websockets": "^10.3.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "decimal.js": "^10.4.3",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "nestjs-pino": "^3.5.0",
    "nodemailer": "^6.10.1",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "pino-http": "^9.0.0",
    "prom-client": "^15.1.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.19",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/uuid": "^9.0.7",
    "dotenv": "^16.3.1",
    "jest": "^29.7.0",
    "pino-pretty": "^10.3.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
