# =============================================================================
# NovEx Terraform — Example Variable Values
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars to version control (it may contain secrets).
# =============================================================================

aws_region   = "us-east-1"
environment  = "dev"
project_name = "novex"
domain_name  = "novex.io"

# Database
db_instance_class = "db.t3.medium"
db_password       = "CHANGE_ME_use_a_strong_password"

# Application secrets
jwt_secret = "CHANGE_ME_generate_with_openssl_rand_base64_32"

# ECS task sizing
backend_cpu           = 512
backend_memory        = 1024
backend_desired_count = 2

web_cpu           = 256
web_memory        = 512
web_desired_count = 2

admin_cpu           = 256
admin_memory        = 512
admin_desired_count = 1

# Redis
redis_node_type = "cache.t3.small"

# Monitoring
alert_email = "ops@novex.io"
