# ============================================================
# NovEx — Environment Configuration Template
# Copy this file to .env and fill in your values
# ============================================================

# ── General ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://novex:novex_dev@localhost:5432/novex
DATABASE_POOL_SIZE=20
DATABASE_SSL=false

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=novex:

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=novex-backend
KAFKA_GROUP_ID=novex-consumer

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=novex.io

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@novex.io

# ── S3 Storage ───────────────────────────────────────────────
S3_BUCKET=novex-dev-storage
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000

# ── KYC Provider (Integration Placeholder) ───────────────────
KYC_PROVIDER=mock
KYC_API_KEY=
KYC_API_SECRET=
KYC_WEBHOOK_SECRET=

# ── Chain Analysis (Integration Placeholder) ─────────────────
CHAIN_ANALYSIS_PROVIDER=mock
CHAIN_ANALYSIS_API_KEY=

# ── Blockchain Nodes (Integration Placeholder) ───────────────
BTC_NODE_URL=
ETH_NODE_URL=
TRON_NODE_URL=

# ── Hot Wallet ───────────────────────────────────────────────
# NEVER commit real private keys. Use HSM/KMS in production.
HOT_WALLET_ENCRYPTION_KEY=CHANGE_ME

# ── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ── Rate Limiting ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Frontend URLs ────────────────────────────────────────────
WEB_APP_URL=http://localhost:3001
ADMIN_APP_URL=http://localhost:3002

# ── Feature Flags ────────────────────────────────────────────
FEATURE_STAKING=false
FEATURE_REFERRAL=true
FEATURE_ADVANCED_ORDERS=false
